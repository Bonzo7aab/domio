# Cloudflare R2 (object storage — replaces Supabase Storage)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Cloudflare Flagship (feature flags — server-side only)
# Dashboard: Compute → Flagship → app "domio" → copy App ID
# API token: My Profile → API Tokens → Custom → Account → Flagship Read
# Create boolean flags: new-tender-system, enhanced-map, advanced-filters, mobile-optimizations
FLAGSHIP_APP_ID=
CLOUDFLARE_FLAGSHIP_API_TOKEN=
# Public bucket URLs (enable public access on each bucket or attach a custom domain)
NEXT_PUBLIC_R2_PUBLIC_URL_JOB_ATTACHMENTS=
NEXT_PUBLIC_R2_PUBLIC_URL_BUILDING_IMAGES=

# Supabase (database + auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# GUS REGON API (company lookup by NIP — server-side only)
GUS_API_KEY=

# Email (optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Sentry (production / CI)
# 1. Create a free project at https://sentry.io — platform: Next.js
# 2. Copy DSN, organization slug, and project slug from project settings
# 3. Create an auth token (org:read, project:releases) for source map uploads in CI only
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
