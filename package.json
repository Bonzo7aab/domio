{
  "name": "domio-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbopack": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings=-1",
    "lint:check": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings=-1 --quiet",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:local": "npm run supabase:start && npm run test:e2e",
    "prepare": "husky",
    "supabase:setup": "bash scripts/setup-local-supabase.sh",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset",
    "supabase:migrate-local": "bash scripts/migrate-local-db.sh",
    "supabase:studio": "open http://localhost:54323 || echo 'Studio is available at: http://localhost:54323 (make sure Supabase is running with: npm run supabase:start)'",
    "storage:migrate-to-r2": "npx tsx scripts/migrate-supabase-storage-to-r2.ts",
    "storage:migrate-to-r2:dry-run": "npx tsx scripts/migrate-supabase-storage-to-r2.ts --dry-run",
    "flagship:check": "npx tsx scripts/check-flagship-connection.ts",
    "flagship:list-permissions": "npx tsx scripts/list-cloudflare-token-permissions.ts"
  },
